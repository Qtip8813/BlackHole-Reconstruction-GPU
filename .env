# QRFT Black Hole Toolkit - Environment Configuration
# =====================================================
# Customize these values for your deployment environment

# ===== DOCKER COMPOSE =====
COMPOSE_PROJECT_NAME=qrft-blackhole-toolkit
COMPOSE_FILE=docker-compose.yml

# ===== GPU/CUDA CONFIGURATION =====
# Set to true to enable GPU support (requires NVIDIA Docker runtime)
ENABLE_GPU=false

# CUDA version for CuPy installation
# Options: 11.x (CUDA 11), 12.x (CUDA 12)
# Auto-detected if left empty; set explicitly if detection fails
CUDA_VERSION=12.x

# NVIDIA GPU device IDs to expose (comma-separated)
# Leave empty for all GPUs, or specify: 0 or 0,1 for multi-GPU
NVIDIA_VISIBLE_DEVICES=all

# ===== PYTHON/RUNTIME =====
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
PYTHONPATH=/app:/app/core:/app/gpu:/app/entropy:/app/pipeline:/app/viz

# ===== RESOURCE LIMITS =====
# CPU and memory constraints for containers
COMPOSE_CPU_LIMIT=4
COMPOSE_MEM_LIMIT=8gb
COMPOSE_CPU_RESERVATION=2
COMPOSE_MEM_RESERVATION=4gb

# ===== JUPYTER (optional) =====
JUPYTER_PORT=8888
JUPYTER_TOKEN=qrft_token_2025
JUPYTER_ENABLE_LAB=true

# ===== DATA PATHS =====
# Volume mount locations (can be overridden per deployment)
OUTPUT_DIR=/app/output
EHT_DATA_DIR=/app/eht_data

# ===== LOGGING =====
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ===== PERFORMANCE TUNING =====
# Number of OpenBLAS threads (for CPU-bound linear algebra)
OPENBLAS_NUM_THREADS=4

# Number of worker threads for scipy/numpy operations
OMP_NUM_THREADS=4

# CuPy memory pool size (in GB, GPU only)
CUPY_MEMORY_POOL_LIMIT=6gb

# ===== BUILD CONFIGURATION =====
# Docker build arguments
DOCKER_BUILDKIT=1
BUILDKIT_PROGRESS=plain
